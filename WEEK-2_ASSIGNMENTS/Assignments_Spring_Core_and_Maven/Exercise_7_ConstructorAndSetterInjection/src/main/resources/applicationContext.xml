<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- BookRepository bean -->
    <bean id="bookRepository" class="com.library.repository.BookRepository"/>

    <!--
        Exercise 7: Constructor Injection — injects a String value via constructor-arg.
                    Setter Injection   — injects bookRepository via property setter.
    -->
    <bean id="bookService" class="com.library.service.BookService">
        <!-- Constructor Injection: passes libraryName as a constructor argument -->
        <constructor-arg value="City Central Library"/>

        <!-- Setter Injection: wires BookRepository via setter method -->
        <property name="bookRepository" ref="bookRepository"/>
    </bean>

</beans>
